# Renomeie este arquivo para .env e preencha os valores

# Chave secreta do Flask — gere uma com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# Dados da empresa (aparecem nos orçamentos, pedidos e ficha de custo)
EMPRESA_NOME=Minha Gráfica
EMPRESA_CIDADE=Cidade — UF
EMPRESA_TELEFONE=(00) 00000-0000
EMPRESA_SITE=minhagrafica.com.br

# Caminho do banco de dados SQLite (opcional, padrão: grafica.db)
# DATABASE_PATH=grafica.db

# Defina como 1 SOMENTE se o sistema rodar atrás de um proxy de confiança
# (nginx + gunicorn). Faz o bloqueio de força-bruta no login enxergar o IP
# real de cada visitante. Em acesso direto (localhost/rede local), deixe em branco.
# BEHIND_PROXY=1
